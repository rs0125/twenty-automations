PORT=3000

DATABASE_URL=

TWENTY_CRM_BASE_URL=
TWENTY_CRM_API_KEY=

OPENAI_API_KEY=

RESEND_API_KEY=
RESEND_FROM=

# Shared secret for /send-reminder. Must match the X-Auth header value in
# sql/pg_cron_reminders.sql. Without it, the endpoint refuses all requests.
REMINDER_SECRET=

# Comma-separated list of Twenty `assignedTo` enum values (uppercased first
# names of workspace members). The /rfq parser uses this to validate names
# extracted from WhatsApp messages. Anything not in this list is silently
# ignored. Update + restart whenever a teammate is added/removed in Twenty.
ASSIGNABLE_USERS=DHAVAL,JAYANTH,NIKESH,RANITA,MANEESH,ARNAV,MANOHARI,NIHAS,RAGHAV
